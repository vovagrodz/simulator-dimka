{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "simulator-dimka",
  "main": "worker.js",
  "compatibility_date": "2024-12-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
